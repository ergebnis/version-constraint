{
  "name": "ergebnis/version-constraint",
  "description": "Provides abstractions of version constraints.",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "version",
    "constraint"
  ],
  "authors": [
    {
      "name": "Andreas Möller",
      "email": "am@localheinz.com",
      "homepage": "https://localheinz.com"
    }
  ],
  "homepage": "https://github.com/ergebnis/version-constraint",
  "support": {
    "issues": "https://github.com/ergebnis/version-constraint/issues",
    "source": "https://github.com/ergebnis/version-constraint",
    "security": "https://github.com/ergebnis/version-constraint/blob/main/.github/SECURITY.md"
  },
  "require": {
    "php": "~7.4.0 || ~8.0.0 || ~8.1.0 || ~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0"
  },
  "require-dev": {
    "composer/semver": "^3.4.4",
    "ergebnis/composer-normalize": "^2.52.0",
    "ergebnis/license": "^2.7.0",
    "ergebnis/php-cs-fixer-config": "^6.63.0",
    "ergebnis/phpstan-rules": "^2.13.1",
    "ergebnis/phpunit-slow-test-detector": "^2.24.0",
    "ergebnis/rector-rules": "^1.18.3",
    "fakerphp/faker": "^1.24.1",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.2.2",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-phpunit": "^2.0.18",
    "phpstan/phpstan-strict-rules": "^2.0.11",
    "phpunit/phpunit": "^9.6.34",
    "rector/rector": "^2.5.3"
  },
  "autoload": {
    "psr-4": {
      "Ergebnis\\VersionConstraint\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ergebnis\\VersionConstraint\\Test\\": "test/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": true
    },
    "audit": {
      "abandoned": "report"
    },
    "platform": {
      "php": "7.4.33"
    },
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  }
}
